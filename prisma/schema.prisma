generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          String                           @id @default(uuid())
  firstName                   String
  lastName                    String
  email                       String                           @unique
  phone                       String?
  password                    String?
  schoolId                    String?
  locationId                  String?
  createdAt                   DateTime                         @default(now())
  updatedAt                   DateTime                         @updatedAt
  emailVerified               Boolean                          @default(false)
  classId                     String?
  roleId                      String
  status                      String                           @default("ACTIVE")
  studentId                   String?                          @unique
  parentId                    String?
  adminNotifications          AdminNotification[]
  counselorNotifications      CounselorNotification[]
  adminProfile                AdminProfile?
  artJournals                 ArtJournal[]
  completions                 ArticleCompletion[]              @relation("UserCompletions")
  articles                    Article[]                        @relation("UserArticles")
  audioJournals               AudioJournal[]
  createdBadges               Badge[]                          @relation("BadgeCreator")
  challengeAssignments        ChallengeAssignment[]            @relation("ChallengeAssigner")
  challengeTargetAssignments  ChallengeAssignment[]            @relation("ChallengeTargetUser")
  createdChallenges           Challenge[]                      @relation("ChallengeCreator")
  chatSessions                ChatSession[]
  counselorCounselingSessions CounselingSession[]              @relation("CounselingSessionCounselor")
  studentCounselingSessions   CounselingSession[]              @relation("CounselingSessionStudent")
  counselorAssignments        CounselorAssignment[]            @relation("CounselorAssignments")
  studentAssignments          CounselorAssignment[]            @relation("StudentAssignments")
  counselorProfile            CounselorProfile?
  dailyLogins                 DailyLogin[]
  escalationAlerts            EscalationAlert[]
  highRiskAlerts              HighRiskAlert[]
  meditations                 Meditation[]                     @relation("UserMeditations")
  meditationInstructions      MeditationListeningInstruction[] @relation("UserMeditationInstruction")
  moodCheckins                MoodCheckin[]
  musicInstructions           MusicInstruction[]               @relation("UserMusicInstruction")
  musicTherapy                MusicTherapy[]                   @relation("UserMusic")
  counselorParentMeetings     ParentMeeting[]                  @relation("ParentMeetingCounselor")
  studentParentMeetings       ParentMeeting[]                  @relation("ParentMeetingStudent")
  parentProfile               ParentProfile?                   @relation("ParentProfile")
  ratings                     Rating[]                         @relation("UserRatings")
  resourceAccess              ResourceAccess[]
  savedArticles               SavedArticle[]                   @relation("UserSaves")
  sessions                    Session[]
  streaks                     Streak?
  studentProfile              StudentProfile?
  summaries                   Summary[]
  triggerSelections           TriggerSelection[]
  userBadges                  UserBadge[]
  userChallenges              UserChallenge[]
  classRef                    Class?                           @relation(fields: [classId], references: [id])
  location                    SchoolLocation?                  @relation(fields: [locationId], references: [id])
  parent                      User?                            @relation("StudentParent", fields: [parentId], references: [id])
  children                    User[]                           @relation("StudentParent")
  role                        Role                             @relation(fields: [roleId], references: [id])
  school                      School?                          @relation(fields: [schoolId], references: [id])
  writingJournals             WritingJournal[]

  @@map("Users")
}

model StudentProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  profileImage String?
  status       String  @default("ACTIVE")
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("StudentProfiles")
}

model AdminProfile {
  id               String            @id @default(uuid())
  userId           String            @unique
  department       String            @default("Student Wellness")
  profileImageUrl  String?
  adminPermissions AdminPermission[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AdminProfiles")
}

model CounselorProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  department      String  @default("Student Counseling")
  profileImageUrl String?
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("CounselorProfiles")
}

model ParentProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  department      String  @default("Parent Services")
  profileImageUrl String?
  user            User    @relation("ParentProfile", fields: [userId], references: [id], onDelete: Cascade)

  @@map("ParentProfiles")
}

model ParentMeeting {
  id              String   @id @default(uuid())
  counselorId     String
  studentId       String
  parentName      String
  date            DateTime
  time            String
  purpose         String
  level           String
  status          String   @default("SCHEDULED")
  notes           String?
  discussion      String?
  recommendations String?
  requestedBy     String   @default("COUNSELOR")
  schoolId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  counselor       User     @relation("ParentMeetingCounselor", fields: [counselorId], references: [id], onDelete: Cascade)
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         User     @relation("ParentMeetingStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("ParentMeetings")
}

model School {
  id                     String                           @id @default(uuid())
  name                   String
  address                String?
  phone                  String?
  email                  String?
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt
  articles               Article[]
  challengeAssignments   ChallengeAssignment[]            @relation("ChallengeAssignmentTargetSchool")
  challenges             Challenge[]
  classes                Class[]
  counselingSessions     CounselingSession[]
  journalingConfig       JournalingToolConfig?
  meditationResources    Meditation[]
  meditationInstructions MeditationListeningInstruction[]
  musicInstructions      MusicInstruction[]
  musicResources         MusicResource[]
  parentMeetings         ParentMeeting[]
  schoolLocations        SchoolLocation[]
  users                  User[]

  @@map("Schools")
}

model SchoolLocation {
  id         String   @id @default(uuid())
  schoolId   String
  name       String
  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?
  notes      String?
  isMain     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  classes    Class[]
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users      User[]

  @@map("SchoolLocations")
}

model Class {
  id                   String                @id @default(uuid())
  name                 String
  grade                Int
  section              String?
  schoolId             String
  locationId           String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  challengeAssignments ChallengeAssignment[] @relation("ChallengeAssignmentClass")
  location             SchoolLocation?       @relation(fields: [locationId], references: [id])
  school               School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  counselingSessions   CounselingSession[]
  users                User[]

  @@map("Classes")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  rolePermissions RolePermission[]
  users           User[]

  @@map("Roles")
}

model Permission {
  id               String            @id @default(uuid())
  name             String            @unique
  module           String
  adminPermissions AdminPermission[]
  rolePermissions  RolePermission[]

  @@map("Permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("RolePermissions")
}

model AdminPermission {
  id             String       @id @default(uuid())
  adminProfileId String
  permissionId   String
  adminProfile   AdminProfile @relation(fields: [adminProfileId], references: [id], onDelete: Cascade)
  permission     Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([adminProfileId, permissionId])
  @@map("AdminPermissions")
}

model ChatSession {
  id        String        @id @default(uuid())
  mood      String?
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  isActive  Boolean       @default(true)
  triggers  String?
  userId    String
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  summaries Summary[]

  @@map("ChatSessions")
}

model ChatMessage {
  id         String      @id @default(uuid())
  sessionId  String
  content    String
  createdAt  DateTime    @default(now())
  senderType SenderType
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ChatMessages")
}

model MoodCheckin {
  id        String   @id @default(uuid())
  mood      String
  notes     String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("MoodCheckins")
}

model TriggerSelection {
  id        String   @id @default(uuid())
  triggers  String[]
  notes     String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("TriggerSelections")
}

model Summary {
  id                String      @id @default(uuid())
  userId            String
  sessionId         String
  mainTopic         String
  conversationStart String
  conversationAbout String
  reflection        String
  createdAt         DateTime    @default(now())
  session           ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Summaries")
}

model JournalingToolConfig {
  id                String  @id @default(uuid())
  schoolId          String  @unique
  enableWriting     Boolean @default(true)
  enableAudio       Boolean @default(true)
  enableArt         Boolean @default(true)
  maxAudioDuration  Int     @default(300)
  autoSaveAudio     Boolean @default(true)
  enableUndo        Boolean @default(true)
  enableRedo        Boolean @default(true)
  enableClearCanvas Boolean @default(true)
  school            School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("JournalingToolConfig")
}

model WritingJournal {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("WritingJournals")
}

model AudioJournal {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  audioUrl  String
  duration  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("AudioJournals")
}

model ArtJournal {
  id        String   @id @default(uuid())
  userId    String
  imageUrl  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("ArtJournals")
}

model JournalingPrompt {
  id        String   @id @default(uuid())
  text      String
  moodIds   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isEnabled Boolean  @default(true)

  @@map("JournalingPrompts")
}

model MusicTherapy {
  id             String         @id @default(uuid())
  title          String
  subtitle       String?
  thumbnailUrl   String?
  audioUrl       String
  durationSec    Int
  category       String?
  supportedMoods String[]
  goal           String?
  status         ResourceStatus @default(DRAFT)
  createdBy      String
  createdAt      DateTime       @default(now())
  admin          User           @relation("UserMusic", fields: [createdBy], references: [id])
}

model Meditation {
  id           String                         @id @default(uuid())
  title        String
  description  String
  thumbnailUrl String?
  format       MeditationFormat
  audioUrl     String?
  videoUrl     String?
  durationSec  Int?
  status       ResourceStatus                 @default(DRAFT)
  createdBy    String
  createdAt    DateTime                       @default(now())
  deletedAt    DateTime?
  instructor   String?
  schoolId     String?
  type         String                         @default("GUIDED")
  updatedAt    DateTime                       @updatedAt
  admin        User                           @relation("UserMeditations", fields: [createdBy], references: [id])
  school       School?                        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  categories   MeditationMeditationCategory[] @relation("MeditationCategories")
  goals        MeditationMeditationGoal[]     @relation("MeditationGoals")
  moods        MeditationMood[]
}

model MeditationMood {
  id           String     @id @default(uuid())
  meditationId String
  moodId       String
  meditation   Meditation @relation(fields: [meditationId], references: [id], onDelete: Cascade)
  mood         MoodLabel  @relation(fields: [moodId], references: [id], onDelete: Cascade)

  @@unique([meditationId, moodId])
}

model MusicInstruction {
  id          String   @id @default(uuid())
  title       String
  description String
  steps       Json
  duration    Int?
  difficulty  String   @default("BEGINNER")
  status      String   @default("DRAFT")
  schoolId    String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  proTip      String?
  creator     User     @relation("UserMusicInstruction", fields: [createdBy], references: [id])
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("MusicInstructions")
}

model MeditationListeningInstruction {
  id          String   @id @default(uuid())
  title       String
  description String
  steps       Json
  duration    Int?
  difficulty  String   @default("BEGINNER")
  status      String   @default("DRAFT")
  createdBy   String?
  schoolId    String?
  resourceId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  proTip      String?
  creator     User?    @relation("UserMeditationInstruction", fields: [createdBy], references: [id])
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("MeditationListeningInstructions")
}

model MeditationMeditationCategory {
  id           String             @id @default(uuid())
  meditationId String
  categoryId   String
  createdAt    DateTime           @default(now())
  category     MeditationCategory @relation("MeditationCategories", fields: [categoryId], references: [id], onDelete: Cascade)
  meditation   Meditation         @relation("MeditationCategories", fields: [meditationId], references: [id], onDelete: Cascade)

  @@unique([meditationId, categoryId])
  @@map("MeditationMeditationCategories")
}

model MeditationMeditationGoal {
  id           String         @id @default(uuid())
  meditationId String
  goalId       String
  createdAt    DateTime       @default(now())
  goal         MeditationGoal @relation("MeditationGoals", fields: [goalId], references: [id], onDelete: Cascade)
  meditation   Meditation     @relation("MeditationGoals", fields: [meditationId], references: [id], onDelete: Cascade)

  @@unique([meditationId, goalId])
  @@map("MeditationMeditationGoals")
}

model MeditationCategory {
  id          String                         @id @default(uuid())
  name        String                         @unique
  description String?
  icon        String?
  color       String?
  status      String                         @default("ACTIVE")
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt
  meditations MeditationMeditationCategory[] @relation("MeditationCategories")

  @@map("MeditationCategories")
}

model MeditationGoal {
  id          String                     @id @default(uuid())
  name        String                     @unique
  description String?
  icon        String?
  color       String?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  meditations MeditationMeditationGoal[] @relation("MeditationGoals")

  @@map("MeditationGoals")
}

model Article {
  id                 String              @id @default(uuid())
  title              String
  subtitle           String?
  author             String
  thumbnailUrl       String?
  description        String
  status             ResourceStatus      @default(DRAFT)
  createdBy          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  averageRating      Float?
  ratingCount        Int?
  readTime           Int?
  schoolId           String?
  views              Int                 @default(0)
  blocks             ArticleBlock[]
  categories         ArticleCategory[]
  completions        ArticleCompletion[] @relation("ArticleCompletions")
  goals              ArticleGoal[]
  moods              ArticleMood[]
  admin              User                @relation("UserArticles", fields: [createdBy], references: [id])
  school             School?             @relation(fields: [schoolId], references: [id])
  bulletListBlocks   BulletListBlock[]
  imageBlocks        ImageBlock[]
  keyTakeawaysBlocks KeyTakeawaysBlock[]
  linkBlocks         LinkBlock[]
  ratings            Rating[]            @relation("ArticleRatings")
  reflectionBlocks   ReflectionBlock[]
  savedArticles      SavedArticle[]      @relation("ArticleSaves")
  sectionBlocks      SectionBlock[]

  @@map("Articles")
}

model Rating {
  id        String   @id @default(uuid())
  articleId String
  score     Int
  studentId String?
  createdAt DateTime @default(now())
  article   Article  @relation("ArticleRatings", fields: [articleId], references: [id], onDelete: Cascade)
  student   User?    @relation("UserRatings", fields: [studentId], references: [id])

  @@unique([articleId, studentId])
  @@map("Ratings")
}

model SavedArticle {
  id        String   @id @default(uuid())
  articleId String
  studentId String?
  createdAt DateTime @default(now())
  article   Article  @relation("ArticleSaves", fields: [articleId], references: [id], onDelete: Cascade)
  student   User?    @relation("UserSaves", fields: [studentId], references: [id])

  @@unique([articleId, studentId])
  @@map("SavedArticles")
}

model ArticleCompletion {
  id        String   @id @default(uuid())
  articleId String
  studentId String?
  createdAt DateTime @default(now())
  article   Article  @relation("ArticleCompletions", fields: [articleId], references: [id], onDelete: Cascade)
  student   User?    @relation("UserCompletions", fields: [studentId], references: [id])

  @@unique([articleId, studentId])
  @@map("ArticleCompletions")
}

model MeditationSave {
  id           String   @id @default(uuid())
  meditationId String
  studentId    String?
  createdAt    DateTime @default(now())

  @@unique([meditationId, studentId])
  @@map("MeditationSaves")
}

model MusicSave {
  id        String   @id @default(uuid())
  musicId   String
  studentId String?
  createdAt DateTime @default(now())

  @@unique([musicId, studentId])
  @@map("MusicSaves")
}

model ArticleMood {
  id        String    @id @default(uuid())
  articleId String
  moodId    String
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  mood      MoodLabel @relation(fields: [moodId], references: [id], onDelete: Cascade)

  @@unique([articleId, moodId])
}

model ArticleGoal {
  id        String    @id @default(uuid())
  articleId String
  goalId    String
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  goal      GoalLabel @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([articleId, goalId])
}

model ArticleCategory {
  id         String        @id @default(uuid())
  articleId  String
  categoryId String
  article    Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category   CategoryLabel @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([articleId, categoryId])
}

model DailyLogin {
  id     String   @id @default(uuid())
  userId String
  date   DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("DailyLogins")
}

model ResourceAccess {
  id        String   @id @default(uuid())
  userId    String
  resource  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("ResourceAccess")
}

model Streak {
  id         String   @id @default(uuid())
  userId     String   @unique
  count      Int      @default(0)
  bestStreak Int      @default(0)
  lastActive DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@map("Streaks")
}

model HighRiskAlert {
  id        String   @id @default(uuid())
  userId    String
  reason    String
  createdAt DateTime @default(now())
  resolved  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])

  @@map("HighRiskAlerts")
}

model EscalationAlert {
  id                      String                @id @default(uuid())
  studentId               String
  studentName             String
  studentClass            String?
  sessionId               String
  category                String
  level                   String
  severity                Float
  confidence              Float
  detectedPhrases         String[]
  context                 String?
  recommendation          String?
  description             String
  detectionMethod         String
  messageContent          String
  messageTimestamp        String
  requiresImmediateAction Boolean               @default(false)
  status                  String                @default("open")
  priority                String                @default("medium")
  assignedTo              String?
  notes                   String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  adminNotifications      AdminNotification[]
  counselorNotifications  CounselorNotification[]
  counselingSession       CounselingSession?
  counselorAssignments    CounselorAssignment[]
  user                    User                  @relation(fields: [studentId], references: [id])

  @@map("EscalationAlerts")
}

model AdminNotification {
  id        String           @id @default(uuid())
  userId    String
  alertId   String?
  type      String
  message   String
  severity  String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?
  alert     EscalationAlert? @relation(fields: [alertId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@map("AdminNotifications")
}

model CounselorNotification {
  id        String           @id @default(uuid())
  userId    String
  alertId   String?
  type      String           // 'system', 'escalation', 'session', 'challenge'
  message   String
  severity  String           // 'low', 'medium', 'high', 'critical'
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?
  alert     EscalationAlert? @relation(fields: [alertId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@map("CounselorNotifications")
}

model MoodLabel {
  id         String           @id @default(uuid())
  name       String           @unique
  type       String           @default("GENERAL")
  articles   ArticleMood[]
  meditation MeditationMood[]
}

model GoalLabel {
  id       String        @id @default(uuid())
  name     String        @unique
  status   String        @default("ACTIVE")
  articles ArticleGoal[]

  @@map("GoalLabels")
}

model CategoryLabel {
  id       String            @id @default(uuid())
  name     String            @unique
  status   String            @default("ACTIVE")
  articles ArticleCategory[]

  @@map("CategoryLabels")
}

model ArticleBlock {
  id        String  @id @default(uuid())
  articleId String
  type      String
  order     Int
  content   Json
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("ArticleBlocks")
}

model ImageBlock {
  id        String  @id @default(uuid())
  articleId String
  order     Int
  src       String
  altText   String?
  caption   String?
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("ImageBlocks")
}

model KeyTakeawaysBlock {
  id        String   @id @default(uuid())
  articleId String
  order     Int
  title     String?
  items     String[]
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("KeyTakeawaysBlocks")
}

model ReflectionBlock {
  id        String  @id @default(uuid())
  articleId String
  order     Int
  heading   String
  content   String
  prompt    String?
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("ReflectionBlocks")
}

model LinkBlock {
  id          String  @id @default(uuid())
  articleId   String
  order       Int
  title       String
  url         String
  description String?
  article     Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("LinkBlocks")
}

model SectionBlock {
  id        String  @id @default(uuid())
  articleId String
  order     Int
  title     String
  content   String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("SectionBlocks")
}

model BulletListBlock {
  id        String   @id @default(uuid())
  articleId String
  order     Int
  title     String
  items     String[]
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("BulletListBlocks")
}

model Session {
  id        String   @id @default(uuid())
  sessionId String   @unique
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MusicMood {
  id             String              @id @default(uuid())
  name           String              @unique
  description    String?
  icon           String?
  color          String?
  status         String              @default("ACTIVE")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  musicResources MusicResourceMood[] @relation("MusicMoods")

  @@map("MusicMoods")
}

model MusicResourceMood {
  id              String        @id @default(uuid())
  musicResourceId String
  moodId          String
  createdAt       DateTime      @default(now())
  mood            MusicMood     @relation("MusicMoods", fields: [moodId], references: [id], onDelete: Cascade)
  musicResource   MusicResource @relation("ResourceMoods", fields: [musicResourceId], references: [id], onDelete: Cascade)

  @@unique([musicResourceId, moodId])
  @@map("MusicResourceMoods")
}

model MusicResource {
  id           String                  @id @default(uuid())
  title        String
  description  String?
  url          String
  duration     Int?
  artist       String?
  album        String?
  coverImage   String?
  isPublic     Boolean                 @default(true)
  schoolId     String?
  categoryId   String?
  status       String                  @default("DRAFT")
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  thumbnailUrl String?
  categories   MusicResourceCategory[] @relation("ResourceCategories")
  goals        MusicResourceGoal[]     @relation("ResourceGoals")
  moods        MusicResourceMood[]     @relation("ResourceMoods")
  category     MusicCategory?          @relation("ResourceCategory", fields: [categoryId], references: [id])
  school       School?                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("MusicResources")
}

model MusicCategory {
  id             String                  @id @default(uuid())
  name           String                  @unique
  description    String?
  icon           String?
  color          String?
  status         String                  @default("ACTIVE")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  musicResources MusicResourceCategory[] @relation("CategoryResources")
  resources      MusicResource[]         @relation("ResourceCategory")

  @@map("MusicCategories")
}

model MusicResourceCategory {
  id              String        @id @default(uuid())
  musicResourceId String
  categoryId      String
  createdAt       DateTime      @default(now())
  category        MusicCategory @relation("CategoryResources", fields: [categoryId], references: [id], onDelete: Cascade)
  musicResource   MusicResource @relation("ResourceCategories", fields: [musicResourceId], references: [id], onDelete: Cascade)

  @@unique([musicResourceId, categoryId])
  @@map("MusicResourceCategories")
}

model MusicGoal {
  id             String              @id @default(uuid())
  name           String              @unique
  description    String?
  icon           String?
  color          String?
  status         String              @default("ACTIVE")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  musicResources MusicResourceGoal[] @relation("MusicGoals")

  @@map("MusicGoals")
}

model MusicResourceGoal {
  id              String        @id @default(uuid())
  musicResourceId String
  goalId          String
  createdAt       DateTime      @default(now())
  goal            MusicGoal     @relation("MusicGoals", fields: [goalId], references: [id], onDelete: Cascade)
  musicResource   MusicResource @relation("ResourceGoals", fields: [musicResourceId], references: [id], onDelete: Cascade)

  @@unique([musicResourceId, goalId])
  @@map("MusicResourceGoals")
}

model Badge {
  id             String      @id @default(uuid())
  name           String
  icon           String
  description    String
  requirement    String
  isActive       Boolean     @default(true)
  type           BadgeType
  conditionValue Int?
  createdBy      String
  createdAt      DateTime    @default(now())
  schoolId       String?
  admin          User        @relation("BadgeCreator", fields: [createdBy], references: [id])
  userBadges     UserBadge[]

  @@map("Badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("UserBadges")
}

model Challenge {
  id                      String                @id @default(uuid())
  name                    String
  description             String
  instructions            String
  isActive                Boolean               @default(true)
  createdBy               String
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  schoolId                String?
  requiresMeditation      Boolean               @default(false)
  requiresMusic           Boolean               @default(false)
  requiresPsychoeducation Boolean               @default(false)
  requiresJournaling      Boolean               @default(false)
  category                String?
  assignmentType          String                @default("INDIVIDUAL")
  endsAt                  DateTime              @default(dbgenerated("(now() + '7 days'::interval)"))
  startsAt                DateTime              @default(now())
  targetClassId           String?
  targetSchoolId          String?
  challengeAssignments    ChallengeAssignment[]
  creator                 User                  @relation("ChallengeCreator", fields: [createdBy], references: [id])
  school                  School?               @relation(fields: [schoolId], references: [id])
  userChallenges          UserChallenge[]

  @@map("Challenges")
}

model UserChallenge {
  id                 String    @id @default(uuid())
  userId             String
  challengeId        String
  startedAt          DateTime?
  completedAt        DateTime?
  status             String    @default("ASSIGNED")
  assignedAt         DateTime  @default(now())
  lastActivityAt     DateTime?
  progressPercentage Int       @default(0)
  challenge          Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("UserChallenges")
}

model ChallengeAssignment {
  id             String    @id @default(uuid())
  challengeId    String
  assignedBy     String
  assignmentType String
  targetUserId   String?
  targetClassId  String?
  targetSchoolId String?
  assignedAt     DateTime  @default(now())
  assigner       User      @relation("ChallengeAssigner", fields: [assignedBy], references: [id])
  challenge      Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  targetClass    Class?    @relation("ChallengeAssignmentClass", fields: [targetClassId], references: [id])
  targetSchool   School?   @relation("ChallengeAssignmentTargetSchool", fields: [targetSchoolId], references: [id])
  targetUser     User?     @relation("ChallengeTargetUser", fields: [targetUserId], references: [id])

  @@map("ChallengeAssignments")
}

model CounselingSession {
  id                String              @id @default(uuid())
  schoolId          String
  studentId         String
  counselorId       String
  escalationId      String?             @unique
  classId           String?
  section           String?
  sessionType       String
  level             String?
  title             String?
  status            SessionStatus       @default(SCHEDULED)
  scheduledAt       DateTime
  startedAt         DateTime?
  endedAt           DateTime?
  notes             String?
  outcome           String?
  followUpNeeded    Boolean             @default(false)
  nextSessionAt     DateTime?
  previousSessionId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  class             Class?              @relation(fields: [classId], references: [id])
  counselor         User                @relation("CounselingSessionCounselor", fields: [counselorId], references: [id], onDelete: Cascade)
  escalation        EscalationAlert?    @relation(fields: [escalationId], references: [id])
  previousSession   CounselingSession?  @relation("SessionPrevious", fields: [previousSessionId], references: [id])
  nextSessions      CounselingSession[] @relation("SessionPrevious")
  school            School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           User                @relation("CounselingSessionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  intake            SessionIntake?
  report            SessionReport?

  @@map("CounselingSessions")
}

model SessionIntake {
  id              String            @id @default(uuid())
  sessionId       String            @unique
  basicInfo       Json              @default("{}")
  complaints      Json              @default("{}")
  factors         Json              @default("{}")
  familyHistory   String            @default("")
  personalHistory Json              @default("{}")
  sessionReport   Json              @default("{}")
  status          String            @default("DRAFT")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  session         CounselingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("SessionIntakes")
}

model SessionReport {
  id              String            @id @default(uuid())
  sessionId       String            @unique
  behavioralTags  String[]          @default([])
  summary         String            @default("")
  recommendations String[]          @default([])
  notes           String            @default("")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  session         CounselingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("SessionReports")
}

model CounselorAssignment {
  id                String           @id @default(uuid())
  counselorId       String
  studentId         String
  escalationAlertId String?
  assignedBy        String?
  level             String?
  assignedAt        DateTime         @default(now())
  status            String           @default("ACTIVE")
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  sessionStatus     String           @default("PENDING")
  counselor         User             @relation("CounselorAssignments", fields: [counselorId], references: [id], onDelete: Cascade)
  escalationAlert   EscalationAlert? @relation(fields: [escalationAlertId], references: [id])
  student           User             @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("CounselorAssignments")
}

enum SenderType {
  STUDENT
  BOT
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MeditationFormat {
  AUDIO
  VIDEO
  TEXT
}

enum BadgeType {
  STREAK
  JOURNAL_COUNT
  ARTICLE_READ
  MEDITATION_COUNT
  MUSIC_COUNT
  MOOD_CHECKIN
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  MISSED
}

model ContactMessage {
  id          String   @id @default(uuid())
  fullName    String
  schoolName  String?
  email       String
  phone       String?
  message     String
  createdAt   DateTime @default(now())

  @@map("ContactMessages")
}
